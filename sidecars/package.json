{
  "name": "core",
  "version": "1.0.0",
  "description": "侧车主运行时：tsup 打包两 worker + pkg 生成二进制",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "build:mac": "SIDECAR_TARGET=aarch64-apple-darwin tsup",
    "build:win": "SIDECAR_TARGET=x86_64-pc-windows-msvc tsup",
    "build:linux": "SIDECAR_TARGET=x86_64-unknown-linux-gnu tsup",
    "dev": "turbo run dev --filter=langchain-serve --filter=pty-host"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pkg": {
    "scripts": [
      "dist/index.js"
    ],
    "assets": [
      "../node_modules/.pnpm/better-sqlite3@12.6.2/node_modules/better-sqlite3/build/**"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.6.0",
    "@langchain/community": "^1.1.22",
    "@langchain/deepseek": "^1.0.16",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.36.0",
    "fs-extra": "^11.3.4",
    "hono": "^4.6.0",
    "node-pty": "^1.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.13",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^6.13.0",
    "dotenv": "^16.4.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2"
  }
}